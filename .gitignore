# ============================================================
# Neural Design Lab Official LP — .gitignore
# ============================================================

# ------------------------------
# 環境変数・シークレット（絶対にコミットしない）
# ------------------------------
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production

# ------------------------------
# ビルド成果物（認証情報が埋め込まれている）
# ビルド済みバンドルはソースから再生成するため除外
# ------------------------------
dist/
dist-ssr/
build/
assets/index-*.js
assets/index-*.css
index.cjs

# ------------------------------
# Node.js
# ------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ------------------------------
# IDE / エディタ
# ------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------
# Claude Code 設定（ローカル専用）
# ------------------------------
.claude/settings.local.json

# ------------------------------
# OS 生成ファイル
# ------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------
# ログ・一時ファイル
# ------------------------------
*.log
*.tmp
*.temp
*.cache
.cache/

# ------------------------------
# Vite
# ------------------------------
.vite/
vite.config.*.timestamp-*
