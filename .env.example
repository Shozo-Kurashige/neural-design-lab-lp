# ============================================================
# Neural Design Lab Official LP — 環境変数テンプレート
# ============================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env は .gitignore により Git 管理対象外です。
# 実際の値を設定してからビルドしてください。
# ============================================================

# ------------------------------
# Firebase 設定
# (Firebase Console → プロジェクト設定 → マイアプリ で確認)
# ------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ------------------------------
# Google Analytics
# (Google Analytics → 管理 → データストリーム で確認)
# ------------------------------
VITE_GA_MEASUREMENT_ID=

# ------------------------------
# MicroCMS
# (microCMS ダッシュボード → API設定 → API キー で確認)
# 注意: このキーは真の秘密情報です。絶対に公開しないでください。
# ------------------------------
VITE_MICROCMS_SERVICE_DOMAIN=
VITE_MICROCMS_API_KEY=

# ------------------------------
# Formspree (お問い合わせフォーム)
# (Formspree ダッシュボード → Forms → フォームID で確認)
# ------------------------------
VITE_FORMSPREE_FORM_ID=

# ------------------------------
# WordPress / GraphQL (ブログ)
# ------------------------------
VITE_WORDPRESS_API_URL=
